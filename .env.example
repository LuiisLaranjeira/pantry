# Client (bundled into the app at build time — never put secret keys here)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1

# Server-only — used by Supabase CLI / edge function deploys, NEVER bundled
# SUPABASE_ACCESS_TOKEN=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
