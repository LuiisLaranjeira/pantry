# Client (bundled into the app at build time — never put secret keys here)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1

# Optional. Without it, Sentry stays silent (no events sent).
# Project DSNs are public — safe to bundle into the client.
# EXPO_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0

# Optional URLs to hosted privacy policy + terms of service. If set, the
# Profile screen shows in-app links to them. Both stores also need the
# privacy URL entered in their console.
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://pantry.example.com/privacy
# EXPO_PUBLIC_TERMS_URL=https://pantry.example.com/terms

# Server-only — used by Supabase CLI / edge function deploys, NEVER bundled
# SUPABASE_ACCESS_TOKEN=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
